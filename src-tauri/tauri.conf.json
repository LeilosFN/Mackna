{
    "build": {
        "beforeDevCommand": "bun run dev:react",
        "beforeBuildCommand": "bun run build",
        "devPath": "../dist",
        "distDir": "../dist"
    },
    "package": {
        "productName": "Leilos Launcher",
        "version": "1.1.2"
    },
    "tauri": {
        "allowlist": {
            "all": true,
            "protocol": {
                "all": true,
                "assetScope": [
                    "*/**"
                ]
            },
            "http": {
                "all": true,
                "scope": [
                    "https://api.leilos.qzz.io/*",
                    "https://cdn.leilos.qzz.io/*"
                ]
            },
            "fs": {
                "all": true,
                "scope": [
                    "*/**"
                ]
            }
        },
        "windows": [
            {
                "fullscreen": false,
                "maximizable": false,
                "resizable": true,
                "title": "Leilos",
                "decorations": false,
                "center": true,
                "transparent": true,
                "minWidth": 900,
                "minHeight": 600,
                "width": 1100,
                "height": 700
            }
        ],
        "security": {
            "csp": null
        },
        "bundle": {
            "active": true,
            "targets": "all",
            "identifier": "leilos.tf",
            "icon": [
                "icons/32x32.png",
                "icons/128x128.png",
                "icons/128x128@2x.png",
                "icons/icon.icns",
                "icons/icon.ico"
            ],
            "resources": [
                "dlls"
            ],
            "windows": {
                "certificateThumbprint": null,
                "digestAlgorithm": "sha256",
                "timestampUrl": ""
            },
            "externalBin": []
        }
    }
}
